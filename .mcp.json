{
  "mcpServers": {
    "mineru-parser": {
      "command": ".claude/mcp/mineru-parser/.venv/bin/python",
      "args": [
        ".claude/mcp/mineru-parser/mcp_server.py"
      ],
      "env": {
        "MINERU_PDF_RENDER_TIMEOUT": "30000"
      }
    },
    "excel": {
      "command": ".claude/mcp/excel/.venv/bin/python",
      "args": [
        ".claude/mcp/excel/mcp_server.py"
      ],
      "env": {}
    },
    "deplot": {
      "command": ".claude/mcp/deplot/.venv/bin/python",
      "args": [
        ".claude/mcp/deplot/mcp_server.py"
      ],
      "env": {}
    },
    "MiniMax": {
      "command": ".claude/mcp/minimax-wrapper.sh",
      "args": [],
      "env": {}
    },
    "cite-graph": {
      "command": ".claude/mcp/cite-graph/.venv/bin/python",
      "args": [
        ".claude/mcp/cite-graph/server.py"
      ],
      "env": {}
    },
    "notebooklm": {
      "command": "python3",
      "args": [".claude/mcp/notebooklm-api/run_mcp.py"],
      "env": {
        "DISPLAY": ":0",
        "HEADLESS": "false"
      }
    }
  }
}